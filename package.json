    "email": "kulkarnishub377@gmail.com"
  },
  "homepage": "https://kulkarnishub377.github.io/Alumni_Management_portal/",
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0"
  },
